		{
			"name": "3. Get All QR Transactions",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v3/qr-payment/transactions?page=1&per_page=10",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v3",
						"qr-payment",
						"transactions"
					],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "10",
							"description": "Items per page"
						},
						{
							"key": "status",
							"value": "APPROVED",
							"description": "Filter by status (PENDING, APPROVED, DECLINED, FAILED)",
							"disabled": true
						},
						{
							"key": "qr_type",
							"value": "DYNAMIC",
							"description": "Filter by QR type (STATIC, DYNAMIC)",
							"disabled": true
						},
						{
							"key": "search",
							"value": "QR-20260112",
							"description": "Search by transaction_id, qr_code, customer_name, invoice_no",
							"disabled": true
						},
						{
							"key": "start_date",
							"value": "2026-01-01",
							"description": "Filter from date (YYYY-MM-DD)",
							"disabled": true
						},
						{
							"key": "end_date",
							"value": "2026-01-31",
							"description": "Filter to date (YYYY-MM-DD)",
							"disabled": true
						}
					]
				},
				"description": "Retrieve all QR code payment transactions with optional filters"
			},
			"response": []
		},
		{
			"name": "4. Get QR Transaction by ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v3/qr-payment/transactions/:id",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v3",
						"qr-payment",
						"transactions",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "1",
							"description": "Transaction ID"
						}
					]
				},
				"description": "Get details of a specific QR payment transaction by ID"
			},
			"response": []
		},
