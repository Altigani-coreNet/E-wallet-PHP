				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"transactionDetails\": {\n        \"amount\": 250.50,\n        \"currency\": \"USD\",\n        \"timestamp\": \"{{$isoTimestamp}}\",\n        \"transactionType\": \"SALE\"\n    },\n    \"qrData\": {\n        \"qrCode\": \"QR987654321ZYXWVU\",\n        \"qrType\": \"STATIC\",\n        \"customerName\": \"Jane Smith\",\n        \"customerId\": \"CUST54321\",\n        \"phoneNumber\": \"+9876543210\",\n        \"email\": \"jane.smith@example.com\",\n        \"walletProvider\": \"MobileWallet\"\n    },\n    \"merchantDetails\": {\n        \"merchantId\": \"1\",\n        \"terminalId\": \"1\"\n    },\n    \"additionalData\": {\n        \"description\": \"Product purchase\",\n        \"orderNumber\": \"ORD-67890\"\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
