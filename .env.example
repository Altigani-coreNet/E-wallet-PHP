APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production: public URL of this SoftPos API (scheme + host + path prefix if any). Must match Google OAuth redirect + nginx forwarded host.
# APP_URL=https://fastpay.sd/api/softpos
# APP_ENV=production
# APP_DEBUG=false

# Trust X-Forwarded-* from reverse proxy (required for correct https:// URLs and Google redirect_uri behind TLS termination).
# TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Adyen Checkout API (https://docs.adyen.com/development-resources/api-credentials/)
ADYEN_API_KEY=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_ENVIRONMENT=test
# Live only: prefix from Customer Area → Developers → API URLs
ADYEN_LIVE_ENDPOINT_URL_PREFIX=
ADYEN_TIMEOUT=30
ADYEN_CONNECTION_TIMEOUT=30
ADYEN_DEFAULT_RETURN_URL="${APP_URL}/payment-return"
ADYEN_DEFAULT_CURRENCY=EUR
# Set true only on local/staging — exposes test payment endpoints on routes/api.php
ADYEN_TEST_ROUTES_ENABLED=false

# Payment SPA: Google OAuth browser return (`{MERCHANT_APP_URL or FRONTEND}/login?google_oauth_code=…`)
# FRONTEND=https://fastpay.sd
# MERCHANT_APP_URL=https://fastpay.sd

# Google OAuth (Laravel Socialite). Register the same URI in Google Cloud → Authorized redirect URIs.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Leave unset to use {APP_URL}/oauth/google/callback, or set explicitly:
# GOOGLE_REDIRECT_URI="${APP_URL}/oauth/google/callback"

# End-customer auth (NestJS parity — local JWT, not Passport)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_GRACE=7d
OTP_MOCK_CODE=111111

# Fixed fee deducted from each customer wallet transfer (recipient receives amount minus fee)
WALLET_TRANSFER_FEE=2
